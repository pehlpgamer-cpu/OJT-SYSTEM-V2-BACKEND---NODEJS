# ========================================
# PRODUCTION ENVIRONMENT - OJT System V2
# ========================================
# Copy this to Vercel Environment Variables
# DO NOT commit real secrets to GitHub

# ========================================
# Application Settings
# ========================================
APP_NAME=OJT System V2
APP_ENV=production
APP_DEBUG=false
APP_PORT=3000

APP_URL=https://ojt-system-v2-backend-nodejs.vercel.app


# ========================================
# Database - Neon PostgreSQL
# ========================================
# Get from Neon Dashboard → Pooler connection string
# IMPORTANT: Use Pooler, NOT Direct connection
DATABASE_URL=postgresql://neondb_owner:npg_kspFft32PVBI@ep-restless-bird-a1jlz6av-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DB_CONNECTION=postgresql

# Connection pool settings (optional, has defaults)
DATABASE_POOL_MAX=3
DATABASE_POOL_IDLE=20000

# ========================================
# Authentication - JWT
# ========================================
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ========================================
# Google OAuth (if using)
# ========================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_PROD_CALLBACK_URL=https://your-vercel-domain.vercel.app/api/auth/google/callback

# ========================================
# Session
# ========================================
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# ========================================
# CORS & Security
# ========================================
# Comma-separated list of allowed origins
