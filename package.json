{
  "name": "ojt-system-v2-backend",
  "version": "2.0.0",
  "description": "OJT System V2 - Node.js/Express Backend API with intelligent job matching",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "set NODE_ENV=test && node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --detectOpenHandles",
    "test:watch": "set NODE_ENV=test && node --experimental-vm-modules node_modules/jest/bin/jest.js --watch --detectOpenHandles",
    "test:unit": "set NODE_ENV=test && node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit --coverage",
    "test:integration": "set NODE_ENV=test && node --experimental-vm-modules node_modules/jest/bin/jest.js tests/integration --coverage",
    "test:verbose": "set NODE_ENV=test && node --experimental-vm-modules node_modules/jest/bin/jest.js --verbose --coverage",
    "seed": "node src/database/seeders/index.js",
    "db:sync": "node sync-schema.js"
  },
  "keywords": [
    "ojt",
    "job-matching",
    "express",
    "sequelize",
    "sqlite"
  ],
  "author": "OJT Team",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.35.0",
    "sqlite3": "^5.1.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "nodemon": "^3.0.0",
    "supertest": "^6.3.0"
  }
}
