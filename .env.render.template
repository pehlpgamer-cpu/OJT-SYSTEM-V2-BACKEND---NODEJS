# Environment Variables for Render Deployment
# This is a TEMPLATE - Do NOT commit this file with actual secrets to GitHub!
# Copy relevant variables to Render dashboard instead.

# ==============================================================================
# APPLICATION CONFIGURATION
# ==============================================================================
APP_NAME=OJT System V2
APP_ENV=production
APP_DEBUG=false
APP_PORT=10000
PORT=10000
NODE_ENV=production

# Replace with your actual Render service URL after deployment
# Format: https://YOUR-SERVICE-NAME.onrender.com
APP_URL=https://ojt-system-v2-api.onrender.com

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
# Use 'postgres' for Render, 'sqlite' for local development
DB_CONNECTION=postgres

# Render PostgreSQL Connection String
# Get this from your Render PostgreSQL dashboard:
# Format: postgres://username:password@host:port/database
# ⚠️ CHANGE THIS to your actual PostgreSQL URL from Render
DATABASE_URL=postgres://ojt_user:PASSWORD@db-silver.c.aivencloud.com:11821/ojt_system

# For local SQLite development (not used in production)
DB_PATH=./database/ojt_system.db

# ==============================================================================
# AUTHENTICATION & SECURITY
# ==============================================================================
# Generate a strong random secret (32+ characters)
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️ CHANGE THIS to a unique, secure value
JWT_SECRET=your_super_secret_jwt_key_here_change_this_to_something_secure_and_long

# JWT expiration time
JWT_EXPIRES_IN=7d

# Bcrypt password hashing rounds (10-12 is standard)
BCRYPT_ROUNDS=10

# ==============================================================================
# CORS - Cross-Origin Resource Sharing
# ==============================================================================
# Comma-separated list of frontend domains that can access this API
# Replace with your actual frontend domain(s)
CORS_ORIGIN=https://your-frontend-domain.com,https://another-domain.com,http://localhost:3000

# ==============================================================================
# GOOGLE OAUTH CONFIGURATION
# ==============================================================================
# Get these from Google Cloud Console (https://console.cloud.google.com)
# 1. Create OAuth 2.0 credentials (Web Application)
# 2. Add Authorized redirect URI: https://ojt-system-v2-api.onrender.com/api/auth/google/callback
# ⚠️ CHANGE THESE to your actual Google OAuth credentials
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Callback URLs for OAuth
GOOGLE_DEV_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
GOOGLE_PROD_CALLBACK_URL=https://ojt-system-v2-api.onrender.com/api/auth/google/callback

# ==============================================================================
# RATE LIMITING
# ==============================================================================
# Time window in milliseconds (900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window
RATE_LIMIT_MAX_REQUESTS=100

# ==============================================================================
# LOGGING
# ==============================================================================
# Log level: 'error', 'warn', 'info', 'debug', 'trace'
LOG_LEVEL=info

# Log file path (on Render, logs are streamed, but can be configured)
LOG_FILE=./logs/app.log

# ==============================================================================
# NOTES FOR RENDER DEPLOYMENT
# ==============================================================================
# 1. Do NOT commit this file with actual secrets to GitHub
# 2. Copy these variables to Render dashboard's Environment Variables section
# 3. Replace all ⚠️ marked values with your actual credentials
# 4. Generate JWT_SECRET using a cryptography tool or:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 5. Get DATABASE_URL from your Render PostgreSQL service
# 6. Get Google OAuth credentials from Google Cloud Console
# 7. Store this file securely (not in version control) for reference
