{
  "version": 2,
  "routes": [
    {
      "src": "/minimal",
      "dest": "/api/minimal.js"
    },
    {
      "src": "/ping",
      "dest": "/api/ping.js"
    },
    {
      "src": "/test",
      "dest": "/api/test.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
