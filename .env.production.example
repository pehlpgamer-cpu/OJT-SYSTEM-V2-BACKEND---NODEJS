# ========================================
# NEON.TECH POSTGRESQL PRODUCTION SETUP
# ========================================

# Application
APP_ENV=production
APP_NAME=OJT System V2
APP_PORT=3000
APP_URL=https://your-vercel-domain.vercel.app
APP_DEBUG=false

# ========================================
# DATABASE - Neon.tech PostgreSQL
# ========================================
# Get this connection string from:
# 1. Login to https://console.neon.tech
# 2. Select your project
# 3. Click on "Pooler" connection string (NOT direct)
# 4. Copy the full URL including ?sslmode=require

DATABASE_URL=postgresql://neon_user:password@ep-xxxxx.neon.tech/neondb?sslmode=require

# Connection pooling (tuned for Vercel serverless)
# Neon closes idle connections after 5 minutes, so keep it low
DATABASE_POOL_MAX=3
DATABASE_POOL_IDLE=20000

# SSL is required by Neon
DATABASE_SSL=true

# ========================================
# AUTHENTICATION
# ========================================
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ========================================
# GOOGLE OAUTH (if using)
# ========================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_PROD_CALLBACK_URL=https://your-vercel-domain.vercel.app/api/auth/google/callback

# ========================================
# CORS & SECURITY
# ========================================
CORS_ORIGIN=https://your-frontend-domain.com,https://www.your-frontend-domain.com

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=info
