# ========================================
# Rate Limiting
# ========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# Logging
# ========================================
LOG_LEVEL=info

# ========================================
# Node Environment
# ========================================
NODE_ENV=production